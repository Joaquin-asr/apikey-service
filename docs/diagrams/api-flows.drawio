        <!-- ── Decision: ambos headers presentes? ── -->
        <mxCell id="104" value="¿Headers X-Client-Id y&lt;br&gt;X-Renewed-ApiKey-Id&lt;br&gt;presentes y no vacíos?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="200" width="280" height="90" as="geometry"/>
