          <mxGeometry x="30" y="870" width="220" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="15" value="&lt;b&gt;INSERT&lt;/b&gt; api_keys&lt;br&gt;(clientHash, encryptedKey,&lt;br&gt;apiKeyHash, expirationAt, active='1')" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="20" y="950" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="16" value="&lt;b&gt;HTTP 200 OK&lt;/b&gt;&lt;br&gt;APIKEY_CREATED&lt;br&gt;Nuevo ApiKey generado exitosamente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="20" y="1060" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ── Decision: expirada? (solo si existe clave activa) ── -->
        <mxCell id="17" value="¿expirationAt&lt;br&gt;&lt; ahora?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="730" width="280" height="80" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════ -->
