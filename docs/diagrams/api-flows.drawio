          <mxGeometry x="400" y="745" width="280" height="80" as="geometry"/>
        </mxCell>

        <!-- ── Decision: cooldown activo? ── -->
        <mxCell id="113" value="¿renewCooldownUntil&lt;br&gt;!= null AND &gt; ahora?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="860" width="280" height="80" as="geometry"/>
        </mxCell>

        <!-- ── Error 429: COOLDOWN ── -->
