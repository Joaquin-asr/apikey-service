  <diagram id="val" name="POST /validate">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ── START ── -->
        <mxCell id="202" value="POST /api/apikeys/validate" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- ── CorrelationIdFilter ── -->
        <mxCell id="203" value="&lt;b&gt;CorrelationIdFilter&lt;/b&gt;&lt;br&gt;Leer header X-Correlation-Id (generar UUID si ausente)&lt;br&gt;Inyectar en MDC de SLF4J · Agregar al response" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="390" y="100" width="300" height="70" as="geometry"/>
        </mxCell>

        <!-- ── Decision: ambos headers presentes? ── -->
        <mxCell id="204" value="¿Headers X-Client-Id&lt;br&gt;y X-Api-Key&lt;br&gt;presentes y no vacíos?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="200" width="280" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="205" value="&lt;b&gt;HTTP 401&lt;/b&gt;&lt;br&gt;MISSING_PARAMETERS&lt;br&gt;&lt;i&gt;Debe proporcionar los headers requeridos&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="840" y="220" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ── Decision: clientId válido? ── -->
        <mxCell id="206" value="¿SHA-256(clientId)&lt;br&gt;== validClientIdHash?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="325" width="280" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="207" value="&lt;b&gt;HTTP 401&lt;/b&gt;&lt;br&gt;INVALID_CLIENT_ID&lt;br&gt;&lt;i&gt;Cliente no autorizado&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="840" y="340" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ── Process: clientHash ── -->
        <mxCell id="208" value="clientHash = SHA-256(clientId)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="410" y="435" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- ── DB: SELECT READ-ONLY ── -->
        <mxCell id="209" value="&lt;b&gt;SELECT TOP 1&lt;/b&gt; FROM api_keys&lt;br&gt;WHERE client_id = clientHash&lt;br&gt;ORDER BY created_at DESC · [TX READ-ONLY]" style="shape=mxgraph.flowchart.database;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="385" y="515" width="310" height="90" as="geometry"/>
        </mxCell>

        <!-- ── Decision: encontrado y active='1'? ── -->
        <mxCell id="210" value="¿Registro encontrado&lt;br&gt;con active = '1'?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="635" width="280" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="211" value="&lt;b&gt;HTTP 401&lt;/b&gt;&lt;br&gt;APIKEY_NOT_FOUND&lt;br&gt;&lt;i&gt;No se encontró un ApiKey activo para este cliente&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="840" y="650" width="240" height="65" as="geometry"/>
        </mxCell>

        <!-- ── Decision: expirado? ── -->
        <mxCell id="212" value="¿expirationAt&lt;br&gt;&lt; ahora?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="745" width="280" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="213" value="&lt;b&gt;HTTP 401&lt;/b&gt;&lt;br&gt;APIKEY_EXPIRED&lt;br&gt;&lt;i&gt;El ApiKey ha expirado&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="840" y="760" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ── Process: SHA-256 del key provisto ── -->
        <mxCell id="214" value="providedHash = SHA-256(providedApiKey)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="410" y="855" width="260" height="50" as="geometry"/>
        </mxCell>

